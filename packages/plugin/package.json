    "openclaw.plugin.json"
  ],
  "keywords": [
    "openclaw",
    "plugin",
    "rag",
    "qdrant",
    "auto-recall"
  ],
  "license": "MIT",
  "devDependencies": {
    "typescript": "5.5"
  }
}
