{
  "name": "@openclaw-qdrant-rag/plugin",
  "version": "1.0.0",
  "description": "OpenClaw plugin for automatic Qdrant RAG context injection",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
